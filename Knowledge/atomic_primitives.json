    "JP": {
      "リスト長返却": "return len(res.value)",
      "値返却": "return res.value",
      "数独盤面更新": "solved = res.value\n        for i in range(9): \n            for j in range(9): arg1[i][j] = solved[i][j]",
      "行列盤面更新": "r = res.value\n        for i in range(len(arg1)): \n            for j in range(len(arg1)): arg1[i][j] = r[i][j]"
    },
    "EN": {
      "return length": "return len(res.value)",
      "return value": "return res.value",
      "update sudoku": "solved = res.value\n        for i in range(9): \n            for j in range(9): arg1[i][j] = solved[i][j]",
      "update matrix": "r = res.value\n        for i in range(len(arg1)): \n            for j in range(len(arg1)): arg1[i][j] = r[i][j]"
    }
  }
